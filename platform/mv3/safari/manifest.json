{
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_popup": "popup.html"
  },
  "author": "SysAdminDoc (forked from Raymond Hill)",
  "background": {
    "scripts": [
      "/js/background.js"
    ],
    "type": "module",
    "persistent": false
  },
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "18.6"
    }
  },
  "commands": {
    "enter-zapper-mode": {
      "description": "__MSG_zapperTipEnter__"
    },
    "enter-picker-mode": {
      "description": "__MSG_pickerTipEnter__"
    }
  },
  "declarative_net_request": {
    "rule_resources": []
  },
  "default_locale": "en",
  "description": "__MSG_extShortDesc__",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "options_ui": {
    "page": "dashboard.html"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],
  "short_name": "uBlockVanced Lite",
  "version": "0.2.0",
  "web_accessible_resources": [
    {
      "resources": [
        "strictblock.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "zapper-ui.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "picker-ui.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "unpicker-ui.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
